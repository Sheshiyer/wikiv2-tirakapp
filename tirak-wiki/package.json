{
  "name": "tirak-wiki",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "wiki:corpus": "node scripts/build-wiki-corpus.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "worker:dev": "wrangler dev --config workers/rag/wrangler.jsonc",
    "worker:deploy": "wrangler deploy --config workers/rag/wrangler.jsonc",
    "worker:typegen": "wrangler types --config workers/rag/wrangler.jsonc workers/rag/worker-configuration.d.ts",
    "worker:check": "tsc -p workers/rag/tsconfig.json --noEmit",
    "check": "astro check && npm run worker:check"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/react": "^3.0.0",
    "@astrojs/tailwind": "^5.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^5.16.12",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250510.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.15.2"
  }
}
