---
import BaseLayout from '../layouts/BaseLayout.astro';
import { GlassCard } from '../components/GlassCard';
import { ArrowRight, Sparkles, Zap, Smartphone } from 'lucide-react';
---

<BaseLayout title="Tirak Wiki">
	<div class="space-y-12">
		<!-- Hero Section -->
		<section class="text-center space-y-6 py-12 relative overflow-hidden">
             <!-- Background Gradient Blob -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-tirak-purple/20 rounded-full blur-[100px] -z-10"></div>

			<h1 class="text-5xl md:text-7xl font-bold tracking-tight">
				<span class="text-gradient">Tirak Dream Journeys</span>
			</h1>
			<p class="text-xl text-gray-300 max-w-2xl mx-auto">
				Transforming scattered campaign materials into a beautiful, navigable documentation site.
			</p>
            <div class="flex justify-center gap-4">
                <a href="/docs/01-introduction/welcome" class="bg-gradient-to-r from-tirak-pink to-tirak-purple text-white px-8 py-3 rounded-full font-semibold hover:opacity-90 transition-opacity flex items-center gap-2 shadow-lg shadow-tirak-purple/20 hover:shadow-tirak-purple/40">
                    Get Started <ArrowRight size={20} />
                </a>
            </div>
		</section>

		<!-- Features Grid -->
		<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			<GlassCard client:visible>
				<div class="h-12 w-12 rounded-lg bg-gradient-to-br from-tirak-pink/20 to-tirak-purple/20 flex items-center justify-center mb-4">
					<Sparkles className="text-tirak-pink" size={24} />
				</div>
				<h3 class="text-xl font-bold mb-2">Companion-First Playbooks</h3>
				<p class="text-gray-400">
					Recruit, onboard, and retain companions with clear personas, positioning, and voice guidance.
				</p>
			</GlassCard>

			<GlassCard client:visible>
				<div class="h-12 w-12 rounded-lg bg-gradient-to-br from-tirak-pink/20 to-tirak-purple/20 flex items-center justify-center mb-4">
					<Zap className="text-tirak-purple" size={24} />
				</div>
				<h3 class="text-xl font-bold mb-2">Campaign-Ready Assets</h3>
				<p class="text-gray-400">
					Pre-launch ads, email sequences, and social calendars tailored to supply-first growth.
				</p>
			</GlassCard>

             <GlassCard client:visible>
				<div class="h-12 w-12 rounded-lg bg-gradient-to-br from-tirak-pink/20 to-tirak-purple/20 flex items-center justify-center mb-4">
					<Smartphone className="text-blue-400" size={24} />
				</div>
				<h3 class="text-xl font-bold mb-2">Field-Ready Reference</h3>
				<p class="text-gray-400">
					A concise, structured wiki that keeps teams aligned from strategy to execution.
				</p>
			</GlassCard>
		</section>
	</div>
</BaseLayout>
