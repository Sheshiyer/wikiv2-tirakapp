---
import BaseLayout from '../layouts/BaseLayout.astro';
import { GlassCard } from '../components/GlassCard';
---

<BaseLayout title="Page Not Found">
  <div class="max-w-3xl mx-auto">
    <GlassCard className="p-10 text-center space-y-6" client:load>
      <div class="space-y-3">
        <h1 class="text-4xl md:text-5xl font-bold">Page not found</h1>
        <p class="text-gray-300 text-lg">This route does not exist in the Tirak wiki.</p>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/" class="px-5 py-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors text-sm font-semibold">Home</a>
        <a href="/docs/01-introduction/welcome" class="px-5 py-2 rounded-full bg-gradient-to-r from-tirak-pink to-tirak-purple text-white text-sm font-semibold">Start Reading</a>
        <a href="/docs/05-resources/faq" class="px-5 py-2 rounded-full border border-white/20 text-sm font-semibold hover:bg-white/10 transition-colors">FAQ</a>
      </div>
    </GlassCard>
  </div>
</BaseLayout>
