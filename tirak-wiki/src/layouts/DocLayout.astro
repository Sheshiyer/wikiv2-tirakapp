---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { GlassCard } from '../components/GlassCard';

const { title, frontmatter } = Astro.props;
const currentTitle = title || frontmatter?.title || 'Documentation';
const currentSlug = frontmatter?.slug || '';

const allDocs = await getCollection('docs');

const categories = [
  { id: 'introduction', label: 'Welcome' },
  { id: 'foundation', label: 'About Tirak' },
  { id: 'audience', label: 'Your Customers' },
  { id: 'vendor-onboarding', label: 'Partner Onboarding' },
  { id: 'vendor-directory', label: 'Partner Network' },
  { id: 'partner-resources', label: 'Partner Resources' },
  { id: 'campaign', label: 'Marketing Hub' },
  { id: 'resources', label: 'Resources' },
  { id: 'vendor-pipeline', label: 'Partner Portal' },
];

const groupedDocs = categories.map(cat => ({
  name: cat.label,
  items: allDocs
    .filter(doc => doc.data.category === cat.id)
    .sort((a, b) => (a.data.order || 99) - (b.data.order || 99))
}));
---

<BaseLayout title={currentTitle} docSlug={currentSlug} docTitle={currentTitle}>
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Sidebar -->
    <aside class="w-full lg:w-64 flex-shrink-0">
      <div class="sticky top-24 space-y-6">
        {groupedDocs.map(category => (
           (category.items.length > 0) && (
            <div class="space-y-3">
              <h3 class="font-bold text-tirak-pink uppercase tracking-wider text-xs pl-2">{category.name}</h3>
              <GlassCard className="p-3 !bg-white/5" client:idle>
                <ul class="space-y-1">
                  {category.items.map(doc => (
                    <li>
                      <a 
                        href={`/docs/${doc.slug}`} 
                        class="block px-3 py-2 rounded-lg text-sm text-gray-300 hover:text-white hover:bg-white/10 transition-all"
                      >
                        {doc.data.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </GlassCard>
            </div>
          )
        ))}
        
        {/* Fallback if no docs found (during development) */}
        {allDocs.length === 0 && (
           <div class="space-y-3">
              <h3 class="font-bold text-tirak-pink uppercase tracking-wider text-xs pl-2">Navigation</h3>
              <GlassCard className="p-3 !bg-white/5" client:idle>
                <p class="text-sm text-gray-400 px-3 py-2">No documents found.</p>
              </GlassCard>
           </div>
        )}

      </div>
    </aside>

    <!-- Main Content -->
    <article class="flex-1 min-w-0">
        <GlassCard className="p-8 md:p-12 min-h-[80vh]" client:load>
            <div class="mb-8 flex items-center justify-center">
              <img src="/tirak-logo.png" alt="Tirak logo" class="h-12 w-auto" loading="eager" />
            </div>
            <div class="prose prose-invert prose-pink max-w-none prose-headings:font-sans prose-headings:font-bold prose-h1:text-4xl prose-h1:mb-8 prose-h2:text-2xl prose-h2:mt-10 prose-p:text-gray-300 prose-p:leading-relaxed prose-li:text-gray-300">
                <slot />
            </div>
        </GlassCard>
    </article>
  </div>
</BaseLayout>
