---
import '../styles/global.css';
import '../styles/glassmorphism.css';
import { Navigation } from '../components/Navigation';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Tirak Dream Journeys Wiki" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600&family=Noto+Sans+Thai&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-[#0f0f13] text-white min-h-screen">
        <Navigation client:load />
		<main class="pt-24 px-4 max-w-7xl mx-auto pb-12">
			<slot />
		</main>
	</body>
</html>
