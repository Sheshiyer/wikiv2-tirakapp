---
import '../styles/global.css';
import '../styles/glassmorphism.css';
import { Navigation } from '../components/Navigation';
import { ContactButtons } from '../components/ContactButtons';

interface Props {
	title: string;
	docSlug?: string;
	docTitle?: string;
}

const { title, docSlug = '', docTitle = title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Tirak Dream Journeys is a companion-first travel marketplace. Thai companions keep 80–85% of every booking, get same-day approval, and share real local culture on their own terms." />
		<meta name="viewport" content="width=device-width" />

		<!-- Open Graph -->
		<meta property="og:title" content={`${title} | Tirak Dream Journeys`} />
		<meta property="og:description" content="Tirak Dream Journeys is a companion-first travel marketplace. Thai companions keep 80–85% of every booking and share real local culture." />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/tirak-logo.png" />
		<meta property="og:site_name" content="Tirak Dream Journeys" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={`${title} | Tirak Dream Journeys`} />
		<meta name="twitter:description" content="Join 614+ Thailand experience vendors. Keep 80-85% of every booking with Tirak Dream Journeys." />
		<meta name="twitter:image" content="/tirak-logo.png" />

		<!-- Additional SEO -->
		<link rel="canonical" href={`https://wiki.tirak.app${Astro.url.pathname}`} />
		<meta name="robots" content="index, follow" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600&family=Noto+Sans+Thai&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Tirak Dream Journeys Wiki</title>
	</head>
	<body class="bg-[#0f0f13] text-white min-h-screen">
        <Navigation client:load />
		<main class="pt-24 px-4 max-w-7xl mx-auto pb-12">
			<slot />
		</main>
		<ContactButtons client:load docSlug={docSlug} docTitle={docTitle} />
	</body>
</html>
